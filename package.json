{
  "name": "ledgerful-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:links": "next start --port 4173",
    "lint": "eslint",
    "check:preview": "npm run build && node scripts/check-quiet-preview.mjs",
    "check:links": "cross-env NEXT_PUBLIC_SITE_URL=http://127.0.0.1:4173 npm run build && start-server-and-test start:links http://127.0.0.1:4173 \"linkinator http://127.0.0.1:4173 --recurse --skip ^mailto:\""
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "lucide-react": "1.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "cross-env": "10.1.0",
    "linkinator": "7.6.1",
    "start-server-and-test": "3.0.11",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}

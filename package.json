{
  "name": "ledgerful-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build-with-csp.mjs",
    "build:next": "next build --webpack",
    "start": "next start",
    "start:links": "next start --port 4173",
    "lint": "eslint",
    "check:preview": "npm run build && node scripts/check-quiet-preview.mjs",
    "check:pricing": "npm run build && node scripts/check-pricing-truth.mjs",
    "check:links": "cross-env NEXT_PUBLIC_SITE_URL=http://127.0.0.1:4173 npm run build && start-server-and-test start:links http://127.0.0.1:4173 \"linkinator http://127.0.0.1:4173 --recurse --skip ^mailto: --skip github.com/Ryan-AI-Studios/Ledgerful\"",
    "check:trust": "npm run build && node scripts/check-trust-truth.mjs",
    "check:docs": "npm run build && node scripts/check-docs-truth.mjs",
    "check:truth": "node scripts/check-quiet-preview.mjs && node scripts/check-pricing-truth.mjs && node scripts/check-trust-truth.mjs && node scripts/check-docs-truth.mjs && node scripts/check-jsonld.mjs && node scripts/check-launch-truth.mjs && node scripts/check-proof-assets.mjs",
    "check:launch-truth": "node scripts/check-launch-truth.mjs",
    "check:proof-assets": "node scripts/check-proof-assets.mjs",
    "check:launch-truth:live": "cross-env LAUNCH_TRUTH_LIVE=1 node scripts/check-launch-truth.mjs",
    "check:deploy": "node scripts/check-subresource-integrity.mjs && playwright test tests/e2e/public-site.spec.ts --grep \"loads without runtime\"",
    "check:provenance": "node scripts/provenance-check.mjs",
    "check:jsonld": "node scripts/check-jsonld.mjs",
    "generate:og": "node scripts/generate-og-images.mjs",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:run": "playwright test"
  },
  "dependencies": {
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@csstools/postcss-oklab-function": "^5.0.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "linkinator": "7.6.1",
    "parse5": "8.0.1",
    "schema-dts": "^2.0.0",
    "sharp": "^0.35.3",
    "start-server-and-test": "3.0.11",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
